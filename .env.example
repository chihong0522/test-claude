# === Limitless API ===
LIMITLESS_API_KEY=lmts_your_key_here
PRIVATE_KEY=0x_your_private_key_here

# === Markets (comma-separated slugs) ===
MARKET_SLUGS=btc-above-100k-march-2025,eth-above-4k-march-2025

# === Strategy ===
SPLIT_AMOUNT_USDC=10
MIN_COMBINED_ASK=1.02
LP_SPREAD_LIMIT=0.03
MIN_LP_SIZE=100
REPRICE_INTERVAL=60
# Reprice when midpoint drifts more than this (in dollars, e.g. 0.02 = 2 cents)
MIDPOINT_DRIFT_THRESHOLD=0.02

# === Risk ===
MAX_OPEN_POSITIONS=5
MAX_EXPOSURE_USDC=100
