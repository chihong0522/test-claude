# Database (PostgreSQL for production, SQLite for local dev)
PM_DATABASE_URL=postgresql+asyncpg://polymarket:polymarket@localhost:5432/polymarket_research
# PM_DATABASE_URL=sqlite+aiosqlite:///./polymarket_research.db

# Discord notifications
PM_DISCORD_WEBHOOK_URL=

# Server
PM_HOST=0.0.0.0
PM_PORT=8000

# Pipeline schedule (UTC)
PM_PIPELINE_SCHEDULE_HOUR=6
PM_PIPELINE_SCHEDULE_MINUTE=0

# Rate limiting (requests per 10s window, set to 50% of documented max)
PM_GAMMA_RATE_LIMIT=2000
PM_DATA_RATE_LIMIT=2000
PM_CLOB_RATE_LIMIT=7500

# Pipeline tuning
PM_MAX_CONCURRENT_FETCHES=5
PM_LEADERBOARD_TOP_N=500

# Backtest defaults
PM_DEFAULT_INITIAL_CAPITAL=3000.0
PM_DEFAULT_SLIPPAGE_BPS=30
PM_DEFAULT_DELAY_SECONDS=30
PM_DEFAULT_POSITION_PCT=0.02
